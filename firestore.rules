rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidReservation(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'guests', 'datetime', 'status', 'createdAt']) &&
        data.size() >= 7 &&
        data.id is string &&
        data.name is string && data.name.size() <= 100 &&
        data.phone is string && data.phone.size() <= 20 &&
        data.guests is string && data.guests.size() <= 10 &&
        data.datetime is string && data.datetime.size() <= 50 &&
        data.status is string && data.status.size() <= 20 &&
        data.createdAt is string && data.createdAt.size() <= 50;
    }

    match /reservations/{reservationId} {
      // In this specific demo, the admin portal uses simple PIN auth (not Firebase auth).
      // So to allow the admin dash to read & update, we have to allow public reads and updates.
      // In a real production app, we would migrate them to Firebase Auth.
      allow read: if true;
      allow create: if isValidId(reservationId) && isValidReservation(incoming()) && incoming().status == 'Pending';
      allow update: if true;
      allow delete: if false;
    }
  }
}
