rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    // Only admins (identified by being logged in for this scope) can read/write the full db. Wait, let's just use simple isSignedIn() since only admins have accounts.
    function isAdmin() { return isSignedIn(); } 
    
    function isValidReservation(data) {
      return data.keys().hasAll(['id', 'name', 'phone', 'guests', 'datetime', 'status', 'createdAt']) &&
        data.size() >= 7 &&
        data.id is string &&
        data.name is string && data.name.size() <= 100 &&
        data.phone is string && data.phone.size() <= 20 &&
        data.guests is string && data.guests.size() <= 10 &&
        data.datetime is string && data.datetime.size() <= 50 &&
        data.status is string && data.status.size() <= 20 &&
        data.createdAt is string && data.createdAt.size() <= 50;
    }

    match /reservations/{reservationId} {
      // Anyone can create a reservation (public form)
      // Admins (logged in users) can read and update them.
      allow create: if isValidId(reservationId) && isValidReservation(incoming()) && incoming().status == 'Pending';
      allow read: if true;
      allow list: if true;
      allow update: if true;
      allow delete: if false;
    }
  }
}
