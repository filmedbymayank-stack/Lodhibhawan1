{
  "entities": {
    "Reservation": {
      "title": "Reservation",
      "description": "A table reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "Name of the guest" },
        "phone": { "type": "string", "description": "Phone number" },
        "guests": { "type": "string", "description": "Number of guests" },
        "datetime": { "type": "string", "description": "Date and Time of reservation" },
        "status": { "type": "string", "enum": ["Pending", "Confirmed", "Cancelled"] },
        "tableNo": { "type": "string" },
        "createdAt": { "type": "string", "description": "ISO timestamp string format, generated by the client initially" }
      },
      "required": ["id", "name", "phone", "guests", "datetime", "status", "createdAt"]
    }
  },
  "firestore": {
    "/reservations/{reservationId}": {
      "schema": { "$ref": "#/entities/Reservation" },
      "description": "Stores table reservations made by users."
    }
  }
}
